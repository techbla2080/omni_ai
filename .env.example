# ============================================
# OmniAI Production Environment Configuration
# ============================================

# --- API Settings ---
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=False

# --- LLM ---
MODEL_NAME=llama3.2:1b
OLLAMA_BASE_URL=http://ollama:11434

# --- JWT (deploy.sh will auto-generate this) ---
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_ALGORITHM=HS256

# --- Database (deploy.sh will auto-generate password) ---
DB_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://omniai:${DB_PASSWORD}@postgres:5432/omniai
REDIS_URL=redis://redis:6379

# --- API Keys ---
SERPER_API_KEY=your_serper_key_here

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://yourdomain.com/api/v1/auth/google/callback

# --- Domain ---
DOMAIN=yourdomain.com